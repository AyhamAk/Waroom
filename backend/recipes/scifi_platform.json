{
  "name": "scifi_platform",
  "match": {
    "styles": ["scifi"],
    "keywords": ["futuristic", "holographic", "sci-fi", "neon", "cyberpunk", "tech", "drone", "robot", "ai", "vr", "headset", "console"]
  },
  "style": "scifi",
  "scaffold": true,
  "render": {"engine": "EEVEE_NEXT", "samples": 80, "resolution": [1280, 720], "fps": 24, "frames": 120},
  "filmic": {"look": "High Contrast", "exposure": 0.0},
  "world": {"color": "#020208", "strength": 1.0},
  "materials": [
    {"id": "hero_mat", "preset": "chrome"},
    {"id": "accent_mat", "preset": "neon_cyan"}
  ],
  "objects": [
    {"id": "product_body", "primitive": "CUBE", "location": [0, 0, 0.5],
     "scale": [0.6, 0.6, 0.6], "material": "hero_mat",
     "subdivision": 2, "shade_smooth": true,
     "bevel": {"width": 0.04, "segments": 3}},
    {"id": "accent_ring", "primitive": "TORUS", "location": [0, 0, 0.3],
     "scale": [1.0, 1.0, 1.0], "rotation_euler": [0, 0, 0],
     "material": "accent_mat"}
  ],
  "camera": {
    "location": [4.2, -6.8, 2.8], "look_at": [0, 0, 0.5],
    "focal_mm": 24, "dof_distance": 8.0, "fstop": 2.8, "dutch_deg": 4,
    "track": "product_body"
  },
  "animation": {
    "camera_orbit": {"radius": 7.0, "height": 3.0, "start_deg": -90, "end_deg": 180, "frames": 120, "target": [0, 0, 0.5]},
    "scale_in_reveal": {"obj": "product_body", "start_frame": 1, "end_frame": 20},
    "product_float": {"obj": "product_body", "amplitude": 0.2, "frames": 120},
    "bezier_all": true
  },
  "compositor": {"preset": "scifi"}
}
